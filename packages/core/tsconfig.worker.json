{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": false,
    "outDir": "./dist/worker",
    "rootDir": "./src/worker",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "WebWorker"]
  },
  "include": ["src/worker/**/*.ts"]
}
