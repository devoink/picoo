{
  "name": "picoo",
  "version": "0.1.0",
  "description": "Cross-platform WASM image processing library",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./io": {
      "import": "./dist/io.js",
      "types": "./dist/io.d.ts"
    }
  },
  "files": [
    "dist",
    "pkg-web/picoo_core.js",
    "pkg-web/picoo_core.d.ts",
    "pkg-web/picoo_core_bg.wasm",
    "pkg-web/picoo_core_bg.wasm.d.ts",
    "pkg-web/package.json",
    "pkg-mp/picoo_core.js",
    "pkg-mp/picoo_core.d.ts",
    "pkg-mp/picoo_core_bg.wasm",
    "pkg-mp/picoo_core_bg.wasm.d.ts",
    "pkg-mp/picoo_core_bg.wasm.br",
    "pkg-mp/package.json"
  ],
  "sideEffects": [
    "./pkg-web/picoo_core.js",
    "./pkg-mp/picoo_core.js"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/prepare-pkg-mp.mjs",
    "build": "tsc && tsc -p tsconfig.worker.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
