.page {
  padding: 40rpx 32rpx 96rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background:
    radial-gradient(120% 80% at 10% -10%, #e8dfd2 0%, transparent 55%),
    radial-gradient(90% 60% at 100% 0%, #d9e2dc 0%, transparent 50%),
    #f3f1ec;
}

.hero {
  margin-bottom: 24rpx;
}

.brand {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 0.04em;
  line-height: 1.1;
}

.tagline {
  display: block;
  margin-top: 8rpx;
  color: #5c5a55;
  font-size: 24rpx;
}

.status {
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 1.4;
  word-break: break-all;
}

.status--loading {
  background: #ebe6dc;
  color: #5c5a55;
}

.status--ready {
  background: #dde8df;
  color: #1f4d32;
}

.status--error {
  background: #f0d9d4;
  color: #7a2e22;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(26, 26, 26, 0.08);
  border-radius: 20rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.card-head .card-title {
  margin-bottom: 0;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-action {
  color: #5c5a55;
  font-size: 24rpx;
  padding: 8rpx 4rpx;
}

.thumb-scroll {
  display: flex;
  flex-direction: row;
  width: 100%;
  height: 168rpx;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.thumb {
  position: relative;
  flex: 0 0 160rpx;
  width: 160rpx;
  height: 160rpx;
  margin-right: 16rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #ebe7df;
  box-sizing: border-box;
  border: 3rpx solid transparent;
}

.thumb.is-active {
  border-color: #1a1a1a;
}

.thumb-image {
  width: 100%;
  height: 100%;
}

.thumb-badge {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  min-width: 36rpx;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(26, 26, 26, 0.72);
  color: #f7f5f0;
  font-size: 20rpx;
  text-align: center;
}

.progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 0 20rpx;
  padding: 0 4rpx;
}

.progress-track {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  background: #ddd8ce;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #1a1a1a;
}

.progress-text {
  flex: 0 0 auto;
  min-width: 90rpx;
  color: #5c5a55;
  font-size: 22rpx;
  text-align: right;
  font-variant-numeric: tabular-nums;
}

.preview {
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #ebe7df;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview--result {
  background: #e4e9e4;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #6b6860;
}

.placeholder-title {
  font-size: 28rpx;
}

.hint {
  font-size: 22rpx;
  color: #9a968c;
}

.meta {
  margin-top: 16rpx;
  color: #4a4842;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(26, 26, 26, 0.06);
}

.field:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.field--stack {
  flex-direction: column;
  align-items: stretch;
  gap: 8rpx;
}

.field--stack.is-disabled {
  opacity: 0.55;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.label {
  flex: 0 0 auto;
  min-width: 160rpx;
  color: #3f3d38;
  font-size: 26rpx;
}

.value-pill {
  min-width: 72rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #f0ebe3;
  color: #1a1a1a;
  font-size: 24rpx;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.quality-slider {
  width: 100%;
  margin: 8rpx 0 0;
}

.field-hint {
  color: #8a857c;
  font-size: 22rpx;
  line-height: 1.4;
}

.input,
.picker {
  flex: 1;
  min-width: 0;
  min-height: 68rpx;
  padding: 14rpx 18rpx;
  background: #f7f5f0;
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-chevron {
  color: #9a968c;
  font-size: 32rpx;
  line-height: 1;
  transform: translateY(-2rpx);
}

.actions {
  display: flex;
  gap: 16rpx;
  margin: 8rpx 0 24rpx;
}

.btn {
  flex: 1;
  margin: 0 !important;
  padding: 0 !important;
  height: 88rpx;
  line-height: 88rpx !important;
  background: #ebe7df !important;
  color: #1a1a1a !important;
  border-radius: 16rpx !important;
  font-size: 28rpx !important;
  font-weight: 500;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1a1a1a !important;
  color: #f7f5f0 !important;
}

.btn[disabled] {
  opacity: 0.4 !important;
}

.log {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #1a1a1a;
  color: #d7d2c8;
  font-size: 22rpx;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
}
